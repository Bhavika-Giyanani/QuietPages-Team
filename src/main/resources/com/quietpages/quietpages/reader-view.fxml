<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.quietpages.quietpages.controller.ReaderController" fx:id="readerRoot" styleClass="reader-root" stylesheets="@reader.css">

    <!-- ══════════════════════════════════════════════════════════════════════
         TOP TOOLBAR
         LEFT  : ← Back  |  ☰ TOC  |  Book Title
         RIGHT : 🔍 Search  |  Tт Style  |  ⛶ Fullscreen
         ══════════════════════════════════════════════════════════════════════ -->
    <top>
        <HBox fx:id="toolbarBox" styleClass="reader-toolbar" alignment="CENTER_LEFT">

            <!-- Back -->
            <Button fx:id="btnBack" styleClass="reader-toolbar-btn" onAction="#onBack">
                <graphic>
                    <FontIcon iconLiteral="fas-arrow-left" iconSize="15"/>
                </graphic>
                <tooltip>
                    <Tooltip text="Back to Library"/>
                </tooltip>
            </Button>

            <!-- TOC — LEFT side, right after Back -->
            <Button fx:id="btnToc" styleClass="reader-toolbar-btn" onAction="#onToc">
                <graphic>
                    <FontIcon iconLiteral="fas-list-ul" iconSize="15"/>
                </graphic>
                <tooltip>
                    <Tooltip text="Table of Contents"/>
                </tooltip>
            </Button>

            <Separator orientation="VERTICAL" style="-fx-background-color:#222222;-fx-pref-width:1;-fx-padding:10 6 10 6;"/>

            <!-- Book title — expands to fill space -->
            <Label fx:id="lblBookTitle" styleClass="reader-book-title" text="" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>

            <!-- ── RIGHT SIDE ── -->

            <!-- Highlights (future) -->
            <Button fx:id="btnHighlights" styleClass="reader-toolbar-btn" disable="true">
                <graphic>
                    <FontIcon iconLiteral="fas-highlighter" iconSize="15"/>
                </graphic>
                <tooltip>
                    <Tooltip text="Highlights (coming soon)"/>
                </tooltip>
            </Button>

            <!-- Bookmarks (future) -->
            <Button fx:id="btnBookmarks" styleClass="reader-toolbar-btn" disable="true">
                <graphic>
                    <FontIcon iconLiteral="fas-bookmark" iconSize="15"/>
                </graphic>
                <tooltip>
                    <Tooltip text="Bookmarks (coming soon)"/>
                </tooltip>
            </Button>

            <Separator orientation="VERTICAL" style="-fx-background-color:#222222;-fx-pref-width:1;-fx-padding:10 4 10 4;"/>

            <!-- Search -->
            <Button fx:id="btnSearch" styleClass="reader-toolbar-btn" onAction="#onSearch">
                <graphic>
                    <FontIcon iconLiteral="fas-search" iconSize="15"/>
                </graphic>
                <tooltip>
                    <Tooltip text="Search"/>
                </tooltip>
            </Button>

            <!-- Read Aloud (future) -->
            <Button fx:id="btnReadAloud" styleClass="reader-toolbar-btn" disable="true">
                <graphic>
                    <FontIcon iconLiteral="fas-volume-up" iconSize="15"/>
                </graphic>
                <tooltip>
                    <Tooltip text="Read Aloud (coming soon)"/>
                </tooltip>
            </Button>

            <Separator orientation="VERTICAL" style="-fx-background-color:#222222;-fx-pref-width:1;-fx-padding:10 4 10 4;"/>

            <!-- Text Style -->
            <Button fx:id="btnTextStyle" styleClass="reader-toolbar-btn" onAction="#onTextStyle">
                <graphic>
                    <FontIcon iconLiteral="fas-text-height" iconSize="15"/>
                </graphic>
                <tooltip>
                    <Tooltip text="Text Style"/>
                </tooltip>
            </Button>

            <!-- Font (future) -->
            <Button fx:id="btnFont" styleClass="reader-toolbar-btn" disable="true">
                <graphic>
                    <FontIcon iconLiteral="fas-font" iconSize="15"/>
                </graphic>
                <tooltip>
                    <Tooltip text="Font (coming soon)"/>
                </tooltip>
            </Button>

            <Separator orientation="VERTICAL" style="-fx-background-color:#222222;-fx-pref-width:1;-fx-padding:10 4 10 4;"/>

            <!-- Fullscreen -->
            <Button fx:id="btnFullscreen" styleClass="reader-toolbar-btn" onAction="#onFullscreen">
                <graphic>
                    <FontIcon fx:id="iconFullscreen" iconLiteral="fas-expand" iconSize="15"/>
                </graphic>
                <tooltip>
                    <Tooltip text="Toggle Fullscreen"/>
                </tooltip>
            </Button>

        </HBox>
    </top>

    <!-- ══════════════════════════════════════════════════════════════════════
         MAIN READING AREA
         Single WebView added in code to webViewContainer.
         CSS column-count:2 applied via JS → left column = left page,
         right column = right page. One spread = viewportWidth of content.
         ══════════════════════════════════════════════════════════════════════ -->
    <center>
        <StackPane fx:id="readerStack" styleClass="reader-stack">

            <!-- WebView injected programmatically in buildWebView() -->
            <HBox fx:id="webViewContainer" styleClass="reader-pages" StackPane.alignment="CENTER" maxWidth="Infinity" maxHeight="Infinity"/>

            <!-- Previous spread / chapter -->
            <Button fx:id="btnPrevPage" styleClass="reader-nav-btn reader-nav-left" onAction="#onPrevPage" StackPane.alignment="CENTER_LEFT">
                <graphic>
                    <FontIcon iconLiteral="fas-chevron-left" iconSize="20"/>
                </graphic>
            </Button>

            <!-- Next spread / chapter -->
            <Button fx:id="btnNextPage" styleClass="reader-nav-btn reader-nav-right" onAction="#onNextPage" StackPane.alignment="CENTER_RIGHT">
                <graphic>
                    <FontIcon iconLiteral="fas-chevron-right" iconSize="20"/>
                </graphic>
            </Button>

        </StackPane>
    </center>

    <!-- ══════════════════════════════════════════════════════════════════════
         BOTTOM STATUS BAR
         Left: Book › Chapter   spread N/Total
         Right: X.X%
         ══════════════════════════════════════════════════════════════════════ -->
    <bottom>
        <HBox styleClass="reader-statusbar" alignment="CENTER_LEFT">
            <Label fx:id="lblBreadcrumb" styleClass="reader-status-breadcrumb"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblProgress" styleClass="reader-status-progress"/>
        </HBox>
    </bottom>

</BorderPane>
